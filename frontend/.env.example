# ================================================================
# MediQueueAI Frontend - Environment Variables
# ================================================================
# INSTRUCTIONS:
# 1. For LOCAL dev: copy this to .env (values below work as-is)
# 2. For VERCEL: add each variable in Vercel Dashboard ->
#    Project Settings -> Environment Variables
# ================================================================

# --- For LOCAL development (works without changes) ---
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# --- For VERCEL production (replace with your backend URL) ---
# VITE_API_URL=https://YOUR-BACKEND.vercel.app/api
# VITE_SOCKET_URL=https://YOUR-BACKEND.vercel.app
