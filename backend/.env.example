# ================================================================
# MediQueueAI Backend - Environment Variables
# ================================================================
# INSTRUCTIONS:
# 1. For LOCAL dev: copy this to .env and fill in your values
# 2. For VERCEL: add each variable in Vercel Dashboard ->
#    Project Settings -> Environment Variables
# ================================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB Atlas (REQUIRED) ---
# Get free cluster at: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/mediqueue?retryWrites=true&w=majority

# --- JWT Secret (REQUIRED) ---
# Any long random string - keep it secret!
JWT_SECRET=change-this-to-a-long-random-secret-string-in-production

# --- Frontend URL for CORS (REQUIRED in production) ---
# Set to your Vercel frontend URL in production
FRONTEND_URL=http://localhost:5173

# --- Google Gemini AI (OPTIONAL) ---
# Get key at: https://aistudio.google.com/app/apikey
# Leave empty to use rule-based triage (still works great)
GEMINI_API_KEY=

# --- Gmail Email Notifications (OPTIONAL) ---
# Without this, emails are silently skipped - app still works fully
# Setup: Google Account -> Security -> 2-Step Verification -> App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=MediQueueAI <your@gmail.com>

# Admin email to receive doctor registration alerts
ADMIN_EMAIL=admin@yourdomain.com
